{
  "name": "polkadot-agent-platform",
  "private": true,
  "workspaces": [
    "mcp-server",
    "indexer",
    "marketing",
    "app"
  ],
  "scripts": {
    "test": "npm run test:backend && npm run test:sdk && npm run test:examples && npm run test:indexer:api && npm run test:contracts",
    "test:backend": "npm --workspace mcp-server test",
    "test:sdk": "node --test sdk/agent-platform-client.test.mjs",
    "test:examples": "node --test examples/**/*.test.mjs",
    "test:indexer:api": "npm --workspace indexer run test:api",
    "test:contracts": "forge test",
    "dev:app": "npm --workspace averray-app run dev",
    "build:app": "npm --workspace averray-app run build",
    "typecheck:app": "npm --workspace averray-app run typecheck",
    "dev:marketing": "npm --workspace marketing run dev",
    "build:marketing": "ASTRO_TELEMETRY_DISABLED=1 npm --workspace marketing run build",
    "build:site": "npm run build:marketing && node scripts/sync-marketing-site.mjs",
    "dev:indexer": "npm --workspace indexer run dev",
    "start:indexer": "npm --workspace indexer run start",
    "typecheck:indexer": "npm --workspace indexer run typecheck",
    "capture:native-xcm-evidence": "node scripts/ops/capture-native-xcm-evidence.mjs",
    "validate:subscan-xcm": "node scripts/ops/validate-subscan-xcm-source.mjs",
    "validate:native-xcm-evidence": "node scripts/ops/validate-native-xcm-evidence.mjs",
    "exercise:async-xcm": "node scripts/ops/exercise-async-xcm-request.mjs",
    "example:profile-lookup": "node examples/profile-lookup/index.mjs"
  }
}
