# Preferred private/provider RPC when available.
# DWELLER_RPC_URL=https://rpc.dweller.example
# Generic override.
# POLKADOT_RPC_URL=https://your-polkadot-rpc
PONDER_RPC_URL_420420417=https://eth-rpc-testnet.polkadot.io/
PONDER_LOW_MEMORY=false
PONDER_ENABLE_TREASURY=true
PONDER_START_BLOCK_TREASURY=7616012
PONDER_START_BLOCK_ESCROW=7622561
PONDER_START_BLOCK_REPUTATION=7622659
PONDER_START_BLOCK_REGISTRIES=latest
PONDER_START_BLOCK_XCM=latest
PONDER_TREASURY_POLICY_ADDRESS=0xYourTreasuryPolicy
PONDER_ESCROW_CORE_ADDRESS=0xYourEscrowCore
PONDER_AGENT_ACCOUNT_ADDRESS=0xYourAgentAccountCore
PONDER_REPUTATION_SBT_ADDRESS=0xYourReputationSbt
PONDER_DISCOVERY_REGISTRY_ADDRESS=0xYourDiscoveryRegistry
# Optional: enable XcmWrapper request indexing when deployed.
# PONDER_XCM_WRAPPER_ADDRESS=0xYourXcmWrapper

# Optional: external XCM outcome publisher. Supports a generic cursor-based
# feed (`feed`), a first upstream adapter for Subscan XCM (`subscan_xcm`), or
# a disabled-by-default native PAPI skeleton (`native_papi`).
# The indexer stores terminal outcomes durably in its database and serves them
# back through `/xcm/outcomes`.
# XCM_OUTCOME_PUBLISHER_ENABLED=true
# XCM_EXTERNAL_SOURCE_TYPE=feed
# XCM_EXTERNAL_SOURCE_URL=https://observer.example/xcm/outcomes
# XCM_EXTERNAL_SOURCE_AUTH_TOKEN=replace-me
# XCM_SUBSCAN_API_HOST=https://assethub-polkadot.api.subscan.io
# XCM_SUBSCAN_API_KEY=replace-me
# XCM_NATIVE_HUB_WS=wss://polkadot-asset-hub-rpc.polkadot.io
# XCM_NATIVE_BIFROST_WS=wss://replace-with-bifrost-endpoint
# XCM_NATIVE_START_BLOCK=0
# XCM_NATIVE_CONFIRMATIONS=2
# XCM_OUTCOME_PUBLISHER_POLL_MS=30000
# XCM_OUTCOME_PUBLISHER_BATCH_SIZE=25
