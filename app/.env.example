# Operator app — frontend env contract.
#
# NEXT_PUBLIC_* variables are inlined by Next.js at build time and
# end up in the client bundle. Anything you do not want shipped to
# browsers must NOT have the NEXT_PUBLIC_ prefix.

# Where the operator app's `/api/*` rewrite proxies to. Falls back to
# `http://localhost:8787` in dev when unset, and to the same-origin
# proxy configured in next.config.ts when running behind Caddy.
NEXT_PUBLIC_API_BASE_URL=

# Truth-mode flag for the four-state operator UI contract (P2.4).
# When `true`, the app may render fixture/demo data AND a persistent
# `Demo mode — this is not real platform data.` banner is mounted on
# every authed page. When `false` (or unset) the app must never show
# fixture data; empty API responses produce empty/degraded states,
# never seeded activity.
#
# Production deploys MUST set this to `false` (or leave unset — the
# default also resolves to false).
NEXT_PUBLIC_DEMO_MODE=false
