{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/release-input",
  "title": "Release Input",
  "description": "Release readiness review input.",
  "type": "object",
  "properties": {
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "release_id",
    "checklist"
  ],
  "additionalProperties": false
}
