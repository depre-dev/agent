{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/wikipedia-citation-repair-output",
  "title": "Wikipedia Citation Repair Output",
  "description": "Reviewable citation repair proposal for Wikipedia articles.",
  "type": "object",
  "properties": {
    "page_title": {
      "type": "string",
      "minLength": 1
    },
    "revision_id": {
      "type": "string",
      "minLength": 1
    },
    "citation_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "section": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "enum": [
              "dead_link",
              "missing_citation",
              "weak_source",
              "outdated_source",
              "claim_mismatch"
            ]
          },
          "current_claim": {
            "type": "string",
            "minLength": 1
          },
          "evidence_url": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "section",
          "problem",
          "current_claim",
          "evidence_url"
        ],
        "additionalProperties": false
      }
    },
    "proposed_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "change_type": {
            "type": "string",
            "enum": [
              "replace_citation",
              "add_citation",
              "flag_for_editor_review"
            ]
          },
          "target_text": {
            "type": "string",
            "minLength": 1
          },
          "replacement_text": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "change_type",
          "target_text",
          "replacement_text",
          "source_url"
        ],
        "additionalProperties": false
      }
    },
    "review_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "page_title",
    "revision_id",
    "citation_findings",
    "proposed_changes",
    "review_notes"
  ],
  "additionalProperties": false
}
