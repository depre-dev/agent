{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/dependency-remediation-input",
  "type": "object",
  "description": "Dependency vulnerability remediation input from public advisory sources such as OSV/NVD.",
  "required": [
    "ecosystem",
    "packageName",
    "vulnerableVersion",
    "fixedVersion",
    "advisoryIds",
    "instructions"
  ],
  "properties": {
    "ecosystem": {
      "type": "string",
      "enum": ["npm"]
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "vulnerableVersion": {
      "type": "string",
      "minLength": 1
    },
    "fixedVersion": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string"
    },
    "manifestPath": {
      "type": "string"
    },
    "advisoryIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "advisoryUrls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
