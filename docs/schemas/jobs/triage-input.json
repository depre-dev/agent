{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/triage-input",
  "title": "Triage Input",
  "description": "Issue triage input.",
  "type": "object",
  "properties": {
    "report": {
      "type": "string",
      "minLength": 1
    },
    "routingOptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "componentHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "report",
    "routingOptions"
  ],
  "additionalProperties": false
}
