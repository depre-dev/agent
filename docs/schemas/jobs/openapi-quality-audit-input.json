{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/openapi-quality-audit-input",
  "title": "OpenAPI Quality Audit Input",
  "description": "Public OpenAPI quality audit input.",
  "type": "object",
  "properties": {
    "apiTitle": {
      "type": "string",
      "minLength": 1
    },
    "specUrl": {
      "type": "string",
      "minLength": 1
    },
    "localSurface": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "openapiVersion": {
      "type": "string"
    },
    "pathCount": {
      "type": "integer",
      "minimum": 0
    },
    "operationCount": {
      "type": "integer",
      "minimum": 0
    },
    "schemaCount": {
      "type": "integer",
      "minimum": 0
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "required": [
    "apiTitle",
    "specUrl",
    "instructions"
  ],
  "additionalProperties": false
}
