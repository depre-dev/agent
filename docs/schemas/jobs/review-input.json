{
  "$id": "schema://jobs/review-input",
  "title": "Review Input",
  "type": "object",
  "required": ["subject", "reviewScope", "rubric"],
  "properties": {
    "subject": { "type": "string", "minLength": 1 },
    "reviewScope": { "type": "string", "minLength": 1 },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
