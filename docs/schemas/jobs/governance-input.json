{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema://jobs/governance-input",
  "title": "Governance Input",
  "description": "Generic governance job input.",
  "type": "object",
  "properties": {
    "proposal": {
      "type": "string",
      "minLength": 1
    },
    "requestedOutcome": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "proposal",
    "requestedOutcome"
  ],
  "additionalProperties": false
}
