# Copy this file to a private env file before any mainnet deploy.
# Do not commit the filled-in version.
#
# This example matches docs/MAINNET_PARAMETERS.md and is intended as the
# conservative launch profile for Averray v1.

PROFILE=mainnet
MAINNET_CONFIRM=I-understand
MUTATION_BACKEND=required

# RPC + deployer
RPC_URL=https://eth-rpc.polkadot.io/
PRIVATE_KEY=0x<deployer-private-key>

# v1 escrow asset: USDC, Trust-Backed Asset ID 1337, 6 decimals.
# Native DOT is not exposed through an ERC20 precompile.
TOKEN_ADDRESS=0x0000053900000000000000000000000001200000
SUPPORTED_ASSETS_JSON=[{"symbol":"USDC","assetClass":"trust_backed","assetId":1337,"address":"0x0000053900000000000000000000000001200000","decimals":6}]

# Control plane roles
OWNER=0x<multisig-mapped-evm-address>
PAUSER=0x<hot-pauser-eoa>
VERIFIER=0x<verifier-eoa>
ARBITRATOR=0x<arbitrator-eoa>

# Conservative launch policy
DAILY_OUTFLOW_CAP=250000000
BORROW_CAP=25000000
MIN_COLLATERAL_RATIO_BPS=20000
DEFAULT_CLAIM_STAKE_BPS=1000
ONBOARDING_WAIVER_CLAIM_COUNT=3
CLAIM_FEE_BPS=200
MIN_CLAIM_FEE=50000
CLAIM_FEE_VERIFIER_BPS=7000
REJECTION_SKILL_PENALTY=10
REJECTION_RELIABILITY_PENALTY=25
DISPUTE_LOSS_SKILL_PENALTY=35
DISPUTE_LOSS_RELIABILITY_PENALTY=60

# Must remain disabled on mainnet until a real audited strategy path exists.
# WITH_VDOT_MOCK=0
