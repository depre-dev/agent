RPC_URL=https://your-asset-hub-rpc
SIGNER_PRIVATE_KEY=0xyourprivatekey
TREASURY_POLICY_ADDRESS=0xYourTreasuryPolicy
AGENT_ACCOUNT_ADDRESS=0xYourAgentAccountCore
ESCROW_CORE_ADDRESS=0xYourEscrowCore
REPUTATION_SBT_ADDRESS=0xYourReputationSbt
SUPPORTED_ASSETS=DOT:0xYourDotAssetAddress
REDIS_URL=redis://default:password@host:6379
REDIS_NAMESPACE=agent-platform
# In production / strict-auth mode, REDIS_URL is REQUIRED. Set this to 1 only
# when deliberately running on ephemeral in-memory state (dev, CI, short-lived
# demos). Booting without Redis in production otherwise fails fast.
# STATE_STORE_ALLOW_MEMORY=0

# --- Authentication -----------------------------------------------------------
# AUTH_MODE controls whether signed-in JWTs are required on protected routes.
#   strict     (default in production): Authorization: Bearer <jwt> is required.
#               Legacy `?wallet=` query params are rejected with 401.
#   permissive (default when NODE_ENV != "production"): accepts `?wallet=` as
#               a fallback when no token is present. Use for local demos only.
AUTH_MODE=strict
# Comma-separated HS256 signing secrets. The first entry is used to sign new
# tokens; the rest remain accepted during verification to support rotation.
# Each secret must be at least 32 characters. Rotate by prepending a new secret
# and draining traffic before dropping the old one.
AUTH_JWT_SECRETS=please-change-me-to-a-32-char-min-secret
# Domain shown in the SIWE message and validated on /auth/verify.
AUTH_DOMAIN=api.averray.com
# Chain ID shown in the SIWE message and validated on /auth/verify.
AUTH_CHAIN_ID=420420422
# Optional overrides (defaults in parens).
# AUTH_TOKEN_TTL_SECONDS=86400   # 24h
# AUTH_NONCE_TTL_SECONDS=300     # 5m
# Comma-separated wallet addresses granted the "admin" role at sign-in. Admin
# role is required to POST /admin/jobs. Leave unset to disable all admin writes.
# AUTH_ADMIN_WALLETS=0xAdmin1,0xAdmin2
# Comma-separated wallet addresses granted the "verifier" role at sign-in.
# Verifier role is required to POST /verifier/run.
# AUTH_VERIFIER_WALLETS=0xVerifier1

# --- Rate limits --------------------------------------------------------------
# Fixed-window counters shared across workers when REDIS_URL is configured.
# Each pair is {limit, windowSeconds}; requests exceeding the window return 429
# with a Retry-After header. Defaults shown are intentionally conservative.
# RATE_LIMIT_AUTH_NONCE_LIMIT=10
# RATE_LIMIT_AUTH_NONCE_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_VERIFY_LIMIT=10
# RATE_LIMIT_AUTH_VERIFY_WINDOW_SECONDS=60
# RATE_LIMIT_ADMIN_JOBS_LIMIT=60
# RATE_LIMIT_ADMIN_JOBS_WINDOW_SECONDS=60
# RATE_LIMIT_VERIFIER_RUN_LIMIT=120
# RATE_LIMIT_VERIFIER_RUN_WINDOW_SECONDS=60
# RATE_LIMIT_EVENTS_LIMIT=30
# RATE_LIMIT_EVENTS_WINDOW_SECONDS=60
# Set TRUST_PROXY=1 when running behind a reverse proxy (Caddy, Render, nginx)
# so the limiter keys off the forwarded client IP rather than the proxy loopback.
# TRUST_PROXY=1

# --- HTTP transport -----------------------------------------------------------
# Maximum request body size in bytes (default 65536 = 64 KiB). Requests
# exceeding this return 400 invalid_request.
# HTTP_MAX_BODY_BYTES=65536
# Comma-separated origins allowed to make cross-origin requests (browser CORS).
# Leave empty to disable CORS entirely (same-origin only). Use "*" only in
# development — the browser will reject credentialed requests against "*".
# CORS_ALLOWED_ORIGINS=https://app.averray.com,http://localhost:5173
# How long browsers may cache the CORS preflight response (default 600s).
# CORS_MAX_AGE_SECONDS=600

# --- Logging ------------------------------------------------------------------
# JSON logs to stdout/stderr. Level is one of: debug, info, warn, error, silent.
# Defaults: info in production, debug otherwise.
# LOG_LEVEL=info

# --- Observability ------------------------------------------------------------
# Prometheus text-format metrics live at /metrics. Leave METRICS_BEARER_TOKEN
# unset for the standard "scrape any network peer" convention, or set a random
# token when /metrics is publicly reachable. Scrapers then send
# `Authorization: Bearer <token>`.
# METRICS_BEARER_TOKEN=

# Sentry is opt-in: the @sentry/node package is NOT a required dependency. To
# enable, `npm install @sentry/node` in mcp-server, then set SENTRY_DSN. The
# error handler ships 5xx exceptions to Sentry and falls back to log-only
# when Sentry isn't installed or DSN is blank.
# SENTRY_DSN=https://...
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=git-sha-or-tag
# SENTRY_TRACES_SAMPLE_RATE=0
